#include <stdio.h>
#include <sys/types.h>
#include <sys/socket.h>
#include <string.h>


int main(int argc, char *argv[])
{
	int						fd1;
	struct sockaddr_in 		serv_addr;
	fd1 = sokcet(AF_INET, SOCK_STREAM, 0);
	if(fd1 < 0)
	{
		printf("create socket failure: %s\n", strerror(errno));
		return -1;
	}

	memset(&serv_addr, 0, sizeof(serv_addr));
	serv_addr.
	

}
